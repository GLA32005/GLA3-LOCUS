# ═══════════════════════════════════════════════════════════
# Agentic Pentest Framework — 环境变量模板
# 复制为 .env 并填写实际值
# ═══════════════════════════════════════════════════════════

# ⚠️ 注意：全新架构下，LLM 相关的配置（如 LLM_API_KEY, STRONG_BASE_URL）
# 已经彻底从 .env 剥离。请使用 `locus config init` 进行向导配置，
# 它们将被统一管理在项目目录下的 .locus/config.yaml 中。


# ── 存储 ─────────────────────────────────────────────────
# 注意：如设置了 REDIS_PASSWORD，REDIS_URL 中需包含密码（@ 用 %40 转义）
REDIS_URL=redis://:YourRedisPassword%40Here@localhost:6379
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=pentest

# ── REDIS ─────────────────────────────────────────────────
# Docker Compose 中 --requirepass 使用此值
REDIS_PASSWORD=YourRedisPassword@Here

# ── API 服务器 ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8086
API_KEY=changeme-to-a-strong-secret

# ── CORS（可选）────────────────────────────────────────────
# 逗号分隔的允许 Origin 列表。"null" 用于支持 file:// 协议打开 WEBUI
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,null

# ── Mission 配置 ─────────────────────────────────────────
MISSION_FILE=config/mission_example.yaml

# ── 报告输出目录 ─────────────────────────────────────────
REPORT_OUTPUT_DIR=reports
